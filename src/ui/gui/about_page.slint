// about_page.slint — About / links / donate. AboutData global + callbacks preserved.

import { Theme } from "theme.slint";
import { PageScaffold, SectionCard, PushButton, BtnKind } from "widgets.slint";

export global AboutData {
    in property <string> version;
    in property <bool> has_update;
}

export component About inherits Rectangle {
    callback wiki_button_clicked;
    callback discord_button_clicked;
    callback newversion_button_clicked;
    callback patreon_button_clicked;
    callback github_sponsors_button_clicked;
    callback source_code_button_clicked;

    background: Theme.bg;

    PageScaffold {
        title: @tr("About");
        subtitle: "Gopher64 · " + AboutData.version;

        if AboutData.has_update: SectionCard {
            title: @tr("Update available");
            PushButton {
                text: @tr("New version available! Click here to download");
                kind: BtnKind.primary;
                clicked => { root.newversion_button_clicked(); }
            }
        }

        SectionCard {
            title: @tr("Community");
            HorizontalLayout {
                spacing: Theme.sp-3;
                alignment: start;
                PushButton { text: @tr("Wiki"); kind: BtnKind.ghost; clicked => { root.wiki_button_clicked(); } }
                PushButton { text: @tr("Discord Server"); kind: BtnKind.ghost; clicked => { root.discord_button_clicked(); } }
                PushButton { text: @tr("Source Code"); kind: BtnKind.ghost; clicked => { root.source_code_button_clicked(); } }
            }
        }

        SectionCard {
            title: @tr("Support development");
            HorizontalLayout {
                spacing: Theme.sp-3;
                alignment: start;
                PushButton { text: @tr("Donate (via Patreon)"); clicked => { root.patreon_button_clicked(); } }
                PushButton { text: @tr("Donate (via GitHub)"); clicked => { root.github_sponsors_button_clicked(); } }
            }
        }
    }
}
