// netplay_join.slint — browse & join sessions. NetplayData / SettingsData bindings preserved.

import { LineEdit, StandardTableView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { PageScaffold, SectionCard, PushButton, BtnKind } from "widgets.slint";
import { NetplayData } from "netplay_page.slint";
import { SettingsData } from "settings_page.slint";

export component NetplayJoin inherits Rectangle {
    callback refresh_sessions();
    callback select_rom(string);
    callback join_session(string, string, string, string);
    callback close;

    background: Theme.bg;

    PageScaffold {
        title: @tr("Join Session");
        subtitle: @tr("Browse open sessions and connect");

        SectionCard {
            title: @tr("Your details");
            HorizontalLayout {
                spacing: Theme.sp-4;
                VerticalLayout {
                    spacing: Theme.sp-1;
                    horizontal-stretch: 1;
                    Text { text: @tr("Player Name (required)"); color: Theme.text-muted; font-size: Theme.font-small; }
                    LineEdit {
                        placeholder-text: @tr("Enter player name");
                        text: NetplayData.player_name;
                        edited(text) => { NetplayData.player_name = text; }
                    }
                }
                VerticalLayout {
                    spacing: Theme.sp-1;
                    horizontal-stretch: 1;
                    Text { text: @tr("Password (if required)"); color: Theme.text-muted; font-size: Theme.font-small; }
                    LineEdit {
                        placeholder-text: @tr("Enter session password");
                        text: NetplayData.password;
                        edited(text) => { NetplayData.password = text; }
                    }
                }
                VerticalLayout {
                    spacing: Theme.sp-1;
                    alignment: end;
                    PushButton {
                        text: NetplayData.game_name == "" ? @tr("Select ROM") : NetplayData.game_name;
                        kind: BtnKind.ghost;
                        clicked => { root.select_rom(SettingsData.rom_dir); }
                    }
                }
            }
        }

        SectionCard {
            title: @tr("Sessions");
            if NetplayData.pending_refresh: Text {
                text: @tr("Refreshing session list, please wait...");
                color: Theme.text-muted;
                font-size: Theme.font-small;
            }
            if !NetplayData.pending_refresh && NetplayData.sessions.length == 0: Text {
                text: @tr("No sessions available. Please refresh to check again.");
                color: Theme.text-muted;
                font-size: Theme.font-small;
            }
            if !NetplayData.pending_refresh && NetplayData.sessions.length > 0: Text {
                text: @tr("Click a session below to select it.");
                color: Theme.text-muted;
                font-size: Theme.font-small;
            }
            StandardTableView {
                min-height: 220px;
                columns: [
                    { title: @tr("Session Name") },
                    { title: @tr("Game Name") },
                    { title: @tr("Password") },
                    { title: @tr("Cheats") }
                ];
                rows: NetplayData.sessions;
                current-row: NetplayData.current_session;
                current-row-changed(current-row) => {
                    NetplayData.current_session = current-row;
                }
            }
            HorizontalLayout {
                alignment: end;
                PushButton {
                    text: @tr("Refresh Session List");
                    kind: BtnKind.ghost;
                    enabled: !NetplayData.pending_refresh;
                    clicked => {
                        NetplayData.pending_refresh = true;
                        NetplayData.current_session = -1;
                        NetplayData.sessions = [];
                        root.refresh_sessions();
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: Theme.sp-2;
            alignment: end;
            PushButton {
                text: @tr("Cancel");
                kind: BtnKind.ghost;
                clicked => { root.close(); }
            }
            PushButton {
                text: @tr("Join Session");
                enabled: NetplayData.player_name != "" && NetplayData.current_session >= 0 && NetplayData.game_name != "" && !NetplayData.pending_session;
                clicked => {
                    NetplayData.pending_session = true;
                    root.join_session(
                        NetplayData.sessions[NetplayData.current_session][0].text,
                        NetplayData.player_name,
                        NetplayData.game_hash,
                        NetplayData.password);
                }
            }
        }
    }
}
