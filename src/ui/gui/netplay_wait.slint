// netplay_wait.slint — Netplay waiting room (player roster, chat, input delay).
// Logic/bindings preserved verbatim; only the presentation is restyled.

import { TextEdit, SpinBox, LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { PageScaffold, SectionCard, PushButton, Badge, BtnKind } from "widgets.slint";
import { NetplayData } from "netplay_page.slint";

export global NetplayWaitData {
    in-out property <string> motd;
    in-out property <[string]> players;
    in-out property <bool> can_start;
    in-out property <string> chat_text;
    in-out property <int> input_delay;
    in-out property <int> recommended_delay;
    in-out property <bool> game_pal;
    in-out property <int> connected_peers_count;
}

component PlayerSlot inherits Rectangle {
    in property <int> number;
    in property <string> name;
    horizontal-stretch: 1;
    height: 58px;
    border-radius: Theme.r-md;
    background: Theme.surface-variant;
    border-width: 1px;
    border-color: root.name == "" ? Theme.border : Theme.green.with-alpha(0.45);

    HorizontalLayout {
        padding-left: Theme.sp-3;
        padding-right: Theme.sp-3;
        spacing: Theme.sp-3;
        Badge {
            y: (parent.height - self.height) / 2;
            text: "P" + root.number;
            tint: root.name == "" ? Theme.text-faint : Theme.accent;
        }
        Text {
            text: root.name == "" ? @tr("Waiting…") : root.name;
            color: root.name == "" ? Theme.text-faint : Theme.text;
            font-size: Theme.font-body;
            font-weight: Theme.w-medium;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}

export component NetplayWait inherits Rectangle {
    callback send_chat_message(string);
    callback begin_game(int);
    callback close;

    property <bool> is-host: NetplayData.player_name == NetplayWaitData.players[0];
    property <bool> mesh-complete: NetplayWaitData.players.length == (NetplayWaitData.connected_peers_count + 1);

    background: Theme.bg;

    PageScaffold {
        title: @tr("Waiting Room");
        subtitle: NetplayData.session_name + "  ·  " + NetplayData.game_name;

        SectionCard {
            title: @tr("Players");
            HorizontalLayout {
                spacing: Theme.sp-2;
                PlayerSlot { number: 1; name: NetplayWaitData.players[0]; }
                PlayerSlot { number: 2; name: NetplayWaitData.players[1]; }
            }
            Rectangle { height: Theme.sp-2; }
            HorizontalLayout {
                spacing: Theme.sp-2;
                PlayerSlot { number: 3; name: NetplayWaitData.players[2]; }
                PlayerSlot { number: 4; name: NetplayWaitData.players[3]; }
            }
        }

        SectionCard {
            title: @tr("Chat");
            TextEdit {
                read-only: true;
                min-height: 120px;
                text: NetplayWaitData.chat_text;
            }
            Rectangle { height: Theme.sp-2; }
            HorizontalLayout {
                spacing: Theme.sp-2;
                chat_message := LineEdit {
                    placeholder-text: @tr("Enter chat message");
                    horizontal-stretch: 1;
                    key-released(event) => {
                        if (event.text == Key.Return && chat_message.text != "") {
                            root.send_chat_message(chat_message.text);
                            chat_message.text = "";
                        }
                        accept
                    }
                }
                PushButton {
                    text: @tr("Send");
                    enabled: chat_message.text != "";
                    clicked => {
                        root.send_chat_message(chat_message.text);
                        chat_message.text = "";
                    }
                }
            }
        }

        // Host-only input delay control; everyone else sees the MOTD.
        if root.is-host: SectionCard {
            title: @tr("Input Delay");
            Text {
                text: @tr("Lower delay feels more responsive but risks rollback stutter on a slow connection.");
                color: Theme.text-muted;
                font-size: Theme.font-small;
                wrap: word-wrap;
            }
            Rectangle { height: Theme.sp-2; }
            HorizontalLayout {
                spacing: Theme.sp-3;
                alignment: start;
                SpinBox {
                    minimum: 1;
                    maximum: 16;
                    value: NetplayWaitData.input_delay;
                    enabled: NetplayWaitData.recommended_delay != 0;
                    edited => { NetplayWaitData.input_delay = self.value; }
                }
                Text {
                    text: @tr("Recommended:") + " " + (NetplayWaitData.recommended_delay == 0 ? @tr("calculating…") : NetplayWaitData.recommended_delay);
                    color: Theme.text-muted;
                    font-size: Theme.font-small;
                    vertical-alignment: center;
                }
            }
        }
        if !root.is-host: SectionCard {
            title: @tr("Message of the Day");
            Text {
                text: NetplayWaitData.motd;
                color: Theme.text-muted;
                font-size: Theme.font-small;
                wrap: word-wrap;
            }
        }

        HorizontalLayout {
            spacing: Theme.sp-2;
            alignment: end;
            PushButton {
                text: @tr("Cancel");
                kind: BtnKind.ghost;
                clicked => { root.close(); }
            }
            PushButton {
                text: root.mesh-complete ? @tr("Start Game") : @tr("Waiting for peers") + " " + (NetplayWaitData.connected_peers_count + 1) + "/" + NetplayWaitData.players.length;
                enabled: root.is-host && NetplayWaitData.can_start && NetplayWaitData.recommended_delay != 0 && root.mesh-complete;
                clicked => {
                    NetplayWaitData.can_start = false;
                    root.begin_game(NetplayWaitData.input_delay);
                }
            }
        }
    }
}
