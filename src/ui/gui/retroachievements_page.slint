// retroachievements_page.slint — RetroAchievements account + options.
// RAData global + callbacks preserved exactly (ra_toggled signature, clear-on-disable).

import { LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { PageScaffold, SectionCard, SettingRow, Toggle, PushButton, BtnKind } from "widgets.slint";

export global RAData {
    in-out property <bool> enabled;
    in-out property <bool> hardcore;
    in-out property <bool> challenge;
    in-out property <bool> leaderboard;
    in-out property <bool> rich_presence;
    in-out property <bool> ra_logging_in;
    in-out property <bool> ra_show_profile;
    in-out property <bool> ra_softcore_only;
    in-out property <string> ra_username;
    in-out property <string> ra_password;
    in-out property <string> current_user_message;
    out property <string> not_logged_in: @tr("Not currently logged in");
}

export component RetroAchievements inherits Rectangle {
    callback ra_button_clicked(string);
    callback ra_toggled(bool, bool, bool, bool, bool);
    callback ra_games_clicked;
    callback ra_show_profile_clicked;

    background: Theme.bg;

    PageScaffold {
        title: @tr("RetroAchievements");
        subtitle: @tr("Track achievements, leaderboards and Discord presence");

        SectionCard {
            title: @tr("Account");

            HorizontalLayout {
                spacing: Theme.sp-3;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: RAData.current_user_message;
                        color: Theme.text;
                        font-size: Theme.font-body;
                        overflow: elide;
                    }
                }
                if RAData.ra_show_profile: PushButton {
                    text: @tr("View Profile");
                    kind: BtnKind.ghost;
                    enabled: RAData.enabled;
                    clicked => { root.ra_show_profile_clicked(); }
                }
            }

            Rectangle { height: Theme.sp-2; }

            HorizontalLayout {
                spacing: Theme.sp-2;
                username_widget := LineEdit {
                    enabled: RAData.enabled;
                    placeholder-text: @tr("Username");
                    text: RAData.ra_username;
                    horizontal-stretch: 1;
                    edited(t) => { RAData.ra_username = t; }
                }
                password_widget := LineEdit {
                    enabled: RAData.enabled;
                    input-type: password;
                    placeholder-text: @tr("Password");
                    horizontal-stretch: 1;
                    edited(t) => { RAData.ra_password = t; }
                }
                PushButton {
                    text: @tr("Login");
                    enabled: RAData.enabled && !RAData.ra_logging_in && RAData.ra_username != "" && RAData.ra_password != "";
                    clicked => {
                        RAData.ra_logging_in = true;
                        root.ra_button_clicked(RAData.ra_password);
                        RAData.ra_password = "";
                        password_widget.text = "";
                    }
                }
            }
        }

        SectionCard {
            title: @tr("Options");

            SettingRow {
                title: @tr("Enabled");
                description: @tr("Connect to RetroAchievements when a game loads.");
                Toggle {
                    checked: RAData.enabled;
                    toggled(v) => {
                        RAData.enabled = v;
                        if (!RAData.enabled) {
                            RAData.ra_username = "";
                            username_widget.text = "";
                            password_widget.text = "";
                            RAData.current_user_message = RAData.not_logged_in;
                            RAData.ra_show_profile = false;
                        }
                        root.ra_toggled(RAData.enabled, RAData.hardcore, RAData.challenge, RAData.leaderboard, RAData.rich_presence);
                    }
                }
            }
            if !RAData.ra_softcore_only: SettingRow {
                title: @tr("Hardcore Mode");
                description: @tr("Disable savestates and rewind to earn hardcore points.");
                enabled: RAData.enabled;
                Toggle {
                    checked: RAData.hardcore;
                    enabled: RAData.enabled;
                    toggled(v) => {
                        RAData.hardcore = v;
                        root.ra_toggled(RAData.enabled, RAData.hardcore, RAData.challenge, RAData.leaderboard, RAData.rich_presence);
                    }
                }
            }
            SettingRow {
                title: @tr("Challenge Indicators");
                enabled: RAData.enabled;
                Toggle {
                    checked: RAData.challenge;
                    enabled: RAData.enabled;
                    toggled(v) => {
                        RAData.challenge = v;
                        root.ra_toggled(RAData.enabled, RAData.hardcore, RAData.challenge, RAData.leaderboard, RAData.rich_presence);
                    }
                }
            }
            SettingRow {
                title: @tr("Leaderboard Trackers");
                enabled: RAData.enabled;
                Toggle {
                    checked: RAData.leaderboard;
                    enabled: RAData.enabled;
                    toggled(v) => {
                        RAData.leaderboard = v;
                        root.ra_toggled(RAData.enabled, RAData.hardcore, RAData.challenge, RAData.leaderboard, RAData.rich_presence);
                    }
                }
            }
            SettingRow {
                title: @tr("Discord Rich Presence");
                description: @tr("Show the current game and progress on your Discord profile.");
                enabled: RAData.enabled;
                Toggle {
                    checked: RAData.rich_presence;
                    enabled: RAData.enabled;
                    toggled(v) => {
                        RAData.rich_presence = v;
                        root.ra_toggled(RAData.enabled, RAData.hardcore, RAData.challenge, RAData.leaderboard, RAData.rich_presence);
                    }
                }
            }
        }

        HorizontalLayout {
            alignment: start;
            PushButton {
                text: @tr("View Supported Games");
                kind: BtnKind.ghost;
                clicked => { root.ra_games_clicked(); }
            }
        }
    }
}
