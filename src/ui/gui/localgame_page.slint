import { Button, HorizontalBox, VerticalBox, GroupBox, Palette } from "std-widgets.slint";
import { Page } from "page.slint";
import { AboutData, NewVersionButton } from "about_page.slint";

export struct GameEntry {
    path: string,
    title: string,
    art: image,
    has-art: bool,
}

export global State {
    in-out property <bool> game_running;
    in-out property <bool> is_android;
    in-out property <[{a:string, b:string}]> recent_roms;
    // Scanned (desktop) / recent (Android) games shown with box art.
    in-out property <[GameEntry]> games;
}

export component LocalGame inherits Page {
    callback open_rom_button_clicked;
    callback saves_folder_button_clicked;
    callback newversion_button_clicked;
    callback recent_rom_button_clicked(string);
    callback scan_folder_clicked;
    callback launch_game(string);
    title: @tr("Local Game");

    VerticalBox {
        alignment: start;
        HorizontalBox {
            alignment: center;
            Button {
                text: @tr("Open ROM");
                enabled: !State.game_running;
                clicked => {
                    open_rom_button_clicked();
                }
            }
            if !State.is_android: Button {
                text: @tr("Scan Folder");
                enabled: !State.game_running;
                clicked => {
                    scan_folder_clicked();
                }
            }
        }

        if !State.is_android:HorizontalBox {
            alignment: center;
            Button {
                text: @tr("Open Saves Folder");
                clicked => {
                    saves_folder_button_clicked();
                }
            }
        }

        if AboutData.has_update:NewVersionButton {
            newversion_button_clicked => {
                newversion_button_clicked();
            }
        }

        if State.recent_roms.length>0:HorizontalBox {
            alignment: center;
            GroupBox {
                title: @tr("Recent ROMs");
                VerticalLayout {
                    alignment: space-between;
                    for rom in State.recent_roms: Button {
                        text: rom.b;
                        enabled: !State.game_running;
                        clicked => {
                            recent_rom_button_clicked(rom.a);
                        }
                    }
                }
            }
        }

        Rectangle { }

        if State.games.length > 0: GroupBox {
            title: @tr("Library");
            VerticalLayout {
                spacing: 4px;
                for game in State.games: Rectangle {
                    height: 68px;
                    border-radius: 4px;
                    background: touch.has-hover ? Palette.alternate-background : transparent;
                    touch := TouchArea {
                        enabled: !State.game_running;
                        clicked => {
                            root.launch_game(game.path);
                        }
                    }
                    HorizontalBox {
                        Image {
                            width: 44px;
                            height: 60px;
                            image-fit: contain;
                            source: game.art;
                        }
                        Text {
                            text: game.title;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            overflow: elide;
                        }
                    }
                }
            }
        }
    }
}
